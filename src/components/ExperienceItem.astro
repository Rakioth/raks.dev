---
interface Props {
	date: string
	title: string
	company: string
	description: string
}

const { date, title, company, description } = Astro.props
---

<div class="absolute -start-1.5 mt-1.5 h-3 w-3 rounded-full bg-primary-700 dark:bg-primary-400">
</div>
<div class="mb-12 flex-1">
	<time class="text-sm text-gray-800 dark:text-gray-300">{date}</time>
	<h3 class="mt-3 text-xl font-bold text-primary-700 dark:text-primary-400">{title}</h3>
	<h4 class="text-lg font-semibold text-primary-800 dark:text-primary-500">{company}</h4>
</div>
<p class="mb-4 flex-1 text-pretty text-gray-800 dark:text-gray-300">{description}</p>
