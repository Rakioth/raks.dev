---
import NavItems from "@/components/NavItems.astro"
import { MOBILE_MENU_BUTTON_ID, MOBILE_MENU_CONTENT_ID } from "@/consts/mobile-menu"
---

<div
	id={MOBILE_MENU_CONTENT_ID}
	class="pointer-events-none fixed inset-0 flex h-screen w-full items-center justify-center bg-[var(--background-color)] px-10 py-20 before:fixed before:h-screen before:w-full before:bg-[url('/effects/topography.png')] before:bg-[url('/effects/topography.webp')] before:bg-cover before:bg-right-top before:bg-no-repeat before:opacity-25 before:content-[''] lg:hidden"
>
	<nav>
		<NavItems isMobile={true} />
	</nav>
</div>

<style>
	div {
		scrollbar-gutter: stable;
		clip-path: circle(0);
	}

	@media (prefers-reduced-motion: no-preference) {
		div {
			transition: clip-path 0.5s ease-out 0s;
		}
	}

	.toggled {
		pointer-events: all;
		clip-path: circle(100%) !important;
	}
</style>

<script is:inline define:vars={{ MOBILE_MENU_BUTTON_ID, MOBILE_MENU_CONTENT_ID }} data-astro-rerun>
	const menuToggle = document.getElementById(MOBILE_MENU_BUTTON_ID)
	const navDrawer = document.getElementById(MOBILE_MENU_CONTENT_ID)
	const header = document.querySelector("header div:first-of-type")

	function handleMenuToggled() {
		navDrawer.classList.toggle("toggled")
		header.classList.toggle("!animate-none")
		document.body.classList.toggle("overflow-hidden")
		document.body.classList.toggle("lg:overflow-auto")
	}

	function handleResize() {
		const rect = menuToggle.getBoundingClientRect()

		const centerX = rect.left + rect.width / 2
		const centerY = rect.top + rect.height / 2

		navDrawer.style.clipPath = `circle(0 at ${centerX}px ${centerY}px)`
	}

	function handleDebounce(handler, timeout) {
		let timer

		return function () {
			clearTimeout(timer)
			timer = window.setTimeout(handler, timeout)
		}
	}

	const debouncedResize = handleDebounce(handleResize, 300)

	function handleMobileMediaQuery(event) {
		if (event.matches) window.addEventListener("resize", debouncedResize)
		else window.removeEventListener("resize", debouncedResize)
	}

	const mobileMediaQuery = window.matchMedia("(max-width: 1024px)")
	mobileMediaQuery.addEventListener("change", handleMobileMediaQuery)

	document.addEventListener("astro:before-swap", () => {
		mobileMediaQuery.removeEventListener("change", handleMobileMediaQuery)
		window.removeEventListener("resize", debouncedResize)
		document.removeEventListener("menutoggled", handleMenuToggled)
	})

	if (mobileMediaQuery.matches) {
		handleResize()
		window.addEventListener("resize", debouncedResize)
	}
	document.addEventListener("menutoggled", handleMenuToggled)
</script>
