---
interface Props {
	href: string
	isExternal?: boolean
	class?: string
}

const { href, isExternal = true, class: className } = Astro.props
---

<a
	href={href}
	rel={isExternal ? "noopener noreferrer" : undefined}
	target={isExternal ? "_blank" : "_self"}
	class:list={[
		className,
		"relative inline-flex max-w-fit items-center justify-center gap-x-2 overflow-hidden rounded-xl border border-gray-300 bg-gray-100 px-3 py-2 text-gray-800 ease-in before:absolute before:inset-0 before:-z-10 before:origin-right before:bg-gray-800 before:duration-300 before:ease-in focus-visible:outline-none focus-visible:ring focus-visible:ring-primary-700/80 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-800 any-hover:border-gray-500 any-hover:!bg-transparent any-hover:text-gray-100 any-hover:delay-100 any-hover:ease-out before:any-hover:origin-left before:any-hover:scale-x-100 before:any-hover:delay-100 before:any-hover:ease-out motion-safe:transition-[border-color,color,transform] motion-safe:before:scale-x-0 before:motion-safe:transition-transform dark:border-gray-600 dark:bg-[#322663] dark:text-white dark:before:bg-white dark:focus-visible:ring-primary-400/80 dark:focus-visible:ring-offset-white dark:any-hover:border-gray-700 dark:any-hover:text-[#322663]",
	]}
>
	<slot />
</a>
