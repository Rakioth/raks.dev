---
interface Props {
	href: string
	isExternal?: boolean
	class?: string
}

const { href, isExternal = true, class: className } = Astro.props
---

<a
	href={href}
	rel={isExternal ? "noopener noreferrer" : undefined}
	target={isExternal ? "_blank" : "_self"}
	class:list={[
		className,
		"inline-flex max-w-fit items-center justify-center gap-x-2 rounded-xl border border-gray-300 bg-gray-100 px-3 py-2 text-gray-800 focus-visible:outline-none focus-visible:ring focus-visible:ring-primary-700/80 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-800 any-hover:border-gray-500 any-hover:bg-gray-800 any-hover:text-gray-100 motion-safe:transition-[border-color,color] dark:border-gray-600 dark:bg-[#322663] dark:text-white dark:focus-visible:ring-primary-400/80 dark:focus-visible:ring-offset-white dark:any-hover:border-gray-700 dark:any-hover:bg-white dark:any-hover:text-[#322663]",
	]}
>
	<slot />
</a>
