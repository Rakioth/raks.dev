---
import GlassLink from "@/components/portfolio/GlassLink.astro"

interface Props {
	name: string
	description: string
	image: string
	alt: string
	tags: {
		name: string
		class: string
		icon: (_props: Record<string, any>) => any
	}[]
	link: string
}

const { name, description, image, alt, tags, link } = Astro.props
---

<article>
	<GlassLink href={link} class="group flex flex-col gap-8 md:flex-row">
		<picture id={image} class="w-full overflow-hidden rounded-lg shadow-lg md:w-1/2">
			<source type="image/webp" />
			<img
				class="h-56 w-full object-cover object-top motion-safe:transition-transform motion-safe:duration-500 sm:h-full md:group-hover:scale-105"
				alt={alt}
				loading="lazy"
			/>
		</picture>

		<div class="flex w-full flex-col gap-y-2 md:w-1/2 md:max-w-lg">
			<h3 class="text-lg font-bold text-gray-800 dark:text-gray-100">{name}</h3>
			<ul class="flex gap-x-2">
				{
					tags.map((tag) => (
						<li
							class:list={[
								tag.class,
								"flex aspect-square items-center gap-x-2 rounded-full border border-black/20 px-2 py-1 text-xs text-white dark:border-white/40 sm:aspect-auto",
							]}
						>
							<tag.icon class="size-3.5" />
							<span class="hidden sm:block">{tag.name}</span>
						</li>
					))
				}
			</ul>
			<p class="text-pretty text-gray-800 dark:text-gray-300">{description}</p>
		</div>
	</GlassLink>
</article>
