---
import GlassLink from "@/components/GlassLink.astro"

interface Props {
	title: string
	description: string
	image: string
	alt: string
	tags: {
		name: string
		class: string
		icon: (_props: Record<string, any>) => any
	}[]
	link: string
}

const { title, description, image, alt, tags, link } = Astro.props
---

<article>
	<GlassLink
		href={link}
		class="group flex flex-col space-x-0 space-y-8 md:flex-row md:space-x-8 md:space-y-0"
	>
		<div class="w-full overflow-clip rounded-lg shadow-lg md:w-1/2">
			<picture id={image}>
				<source type="image/webp" />
				<img
					class="h-56 w-full object-cover object-top motion-safe:transition-transform motion-safe:duration-500 sm:h-full md:group-hover:scale-105"
					alt={alt}
					loading="lazy"
				/>
			</picture>
		</div>

		<div class="w-full md:w-1/2 md:max-w-lg">
			<h3 class="text-lg font-bold text-gray-800 dark:text-gray-100">{title}</h3>
			<ul class="my-2 flex flex-row flex-wrap gap-2">
				{
					tags.map((tag) => (
						<li
							class:list={[
								tag.class,
								"flex aspect-square items-center gap-x-2 rounded-full border border-black/20 px-2 py-1 text-xs text-white dark:border-white/40 sm:aspect-auto",
							]}
						>
							<tag.icon class="size-3.5" />
							<span class="hidden sm:block">{tag.name}</span>
						</li>
					))
				}
			</ul>
			<p class="text-pretty text-gray-800 dark:text-gray-300">{description}</p>
		</div>
	</GlassLink>
</article>
