---
interface Props {
	href: string
	isExternal?: boolean
	class?: string
}

const { href, isExternal = true, class: className } = Astro.props
---

<a
	href={href}
	rel={isExternal ? "noopener noreferrer" : undefined}
	target={isExternal ? "_blank" : "_self"}
	class:list={[
		className,
		"relative rounded-lg p-4 after:absolute after:inset-0 after:-z-10 after:scale-95 after:rounded-lg after:opacity-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-700 after:any-hover:scale-100 after:any-hover:bg-white/50 after:any-hover:opacity-100 after:any-hover:shadow-lg after:any-hover:ring-1 after:any-hover:ring-black/10 after:any-hover:backdrop-blur after:motion-safe:transition dark:focus-visible:ring-primary-400 after:any-hover:dark:bg-black/50 after:any-hover:dark:ring-white/10",
	]}
>
	<slot />
</a>
